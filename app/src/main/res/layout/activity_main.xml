<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <EditText
        android:id="@+id/editTextSehir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Bir şehir yazın (Örn: Istanbul)"
        android:textSize="20sp"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/buttonGetir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Hava Durumunu Getir"
        android:textSize="18sp"/>

    <TextView
        android:id="@+id/textViewSonuc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Bekleniyor..."
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/buttonGecmis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Geçmiş Aramaları Gör"
        android:backgroundTint="#FF9800"
        android:textSize="16sp"/>

</LinearLayout>